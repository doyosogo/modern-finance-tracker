APP_NAME=Finance Tracker API
DEBUG=false
SECRET_KEY=change-this-development-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Local development example:
DATABASE_URL=postgresql+psycopg://finance_tracker:finance_tracker@localhost:5432/finance_tracker
CORS_ORIGINS=http://localhost:5173

# Production examples:
# DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:5432/DB_NAME
# CORS_ORIGINS=https://your-frontend-domain.com
# SECRET_KEY=replace-with-a-long-random-production-secret
